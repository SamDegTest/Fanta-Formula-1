# F1 Fantasy API Session Cookie
# Recuperalo dal sito ufficiale F1 Fantasy (ispeziona i cookie dopo il login)
F1_API_COOKIE=

# Google Cloud Project Credentials (JSON string)
# Incolla qui l'intero contenuto del file JSON delle credenziali del Service Account
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Gemini API Key
GEMINI_API_KEY=
